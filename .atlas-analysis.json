  "keyFeatures": [
    "Intelligent URL discovery via sitemap, navigation parsing, and recursive crawl",
    "LLM-powered URL filtering and markdown cleanup",
    "Multi-provider LLM support (Ollama, OpenRouter, OpenCode, LM Studio)",
    "5-level scraping fallback chain (cache, native markdown, proxy, HTTP, Playwright)",
    "Real-time SSE progress streaming with synthwave UI",
    "Docker-ready with PagePool optimization",
    "Pause/resume support with checkpoint persistence",
    "Structured JSON and Markdown output formats"
  ],
  "publicApiSurface": [
    "POST /api/jobs - Create crawl job",
    "GET /api/jobs/{id}/events - SSE event stream",
    "GET /api/jobs/{id}/status - Job status",
    "POST /api/jobs/{id}/cancel - Cancel job",
    "POST /api/jobs/{id}/pause - Pause job",
    "POST /api/jobs/{id}/resume - Resume paused job",
    "POST /api/jobs/resume-from-state - Resume from checkpoint",
    "GET /api/providers - List LLM providers",
    "GET /api/models - List available models",
    "GET /api/converters - List HTML converters",
    "GET /api/health/ready - Readiness check",
    "GET /api/info - App metadata"
  ]
}
